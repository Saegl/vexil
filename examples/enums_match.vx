# tagged enums (int-only payloads for now)

enum Shape {
    Circle(int)
    Rect(int, int)
    Point
}

def area(s: Shape) -> int {
    return match s {
        Circle(r) => r * r
        Rect(w, h) => w * h
        Point => 0
    }
}

def main() {
    let c = Shape.Circle(4)
    let r = Shape.Rect(3, 5)
    let p = Shape.Point()
    print(area(c))
    print(area(r))
    print(area(p))
}
